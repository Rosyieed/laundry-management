@model LaundryManagement.Models.Entities.Transaction

@{
    ViewData["Title"] = "Detail Transaksi";
}

@section PageHeader {
    <div class="row">
        <div class="col-sm-6">
            <h3 class="mb-0">Detail Transaksi: @Model.InvoiceNo</h3>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Transaksi</a></li>
                <li class="breadcrumb-item active" aria-current="page">Detail</li>
            </ol>
        </div>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">Keranjang Layanan</h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead class="bg-light">
                            <tr>
                                <th>Layanan</th>
                                <th style="width: 15%">Harga (Rp)</th>
                                <th style="width: 10%">Qty</th>
                                <th style="width: 15%">Diskon (Rp)</th>
                                <th style="width: 20%">Subtotal (Rp)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TransactionDetails)
                            {
                                <tr>
                                    <td>@item.PricelistJasa?.Jasa?.NamaJasa</td>
                                    <td>@item.PriceAtTime.ToString("N0")</td>
                                    <td>@item.Qty</td>
                                    <td>@item.Discount.ToString("N0")</td>
                                    <td class="text-end fw-bold">@item.SubTotal.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="card mt-3 border-0 bg-transparent">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Kembali ke Histori
            </a>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="fa-solid fa-user me-1"></i> Pelanggan</h3>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Nama:</strong> @(Model.Customer?.Name)</p>
                <p class="mb-1"><strong>No. HP:</strong> @(Model.Customer?.PhoneNumber)</p>
                @if(!string.IsNullOrEmpty(Model.Customer?.Address))
                {
                    <p class="mb-1"><strong>Alamat:</strong> @Model.Customer.Address</p>
                }
            </div>
        </div>

        <div class="card card-success card-outline mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="fa-solid fa-money-bill-wave me-1"></i> Ringkasan Transaksi</h3>
            </div>
            <div class="card-body">
                <p class="mb-1 d-flex justify-content-between"><span>Subtotal:</span> <span>Rp @Model.TotalPrice.ToString("N0")</span></p>
                <p class="mb-1 text-danger d-flex justify-content-between"><span>Diskon:</span> <span>-Rp @Model.TotalDiscount.ToString("N0")</span></p>
                <hr>
                <p class="mb-1 d-flex justify-content-between text-success"><strong>TOTAL:</strong> <strong>Rp @Model.GrandTotal.ToString("N0")</strong></p>
                <br/>
                <p class="mb-1"><strong>Status Pembayaran:</strong> @Model.PaymentStatus</p>
                <p class="mb-1"><strong>Metode:</strong> @Model.PaymentMethod</p>
                <p class="mb-1"><strong>Status Order:</strong> @Model.Status</p>
                <p class="mb-1"><strong>Tanggal Order:</strong> @Model.OrderDate.ToString("dd MMM yyyy")</p>
                <p class="mb-0"><strong>Catatan:</strong> @(Model.Notes ?? "-")</p>
            </div>
        </div>
        
        <div class="d-grid gap-2">
            <button class="btn btn-warning shadow-sm font-weight-bold opacity-100" type="button" onclick="printNota()">
                <i class="fa-solid fa-print me-1"></i> Cetak Ulang Nota
            </button>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary mt-2">
                 <i class="fa-solid fa-edit me-1"></i> Edit Transaksi
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function printNota() {
            var printWindow = window.open('@Url.Action("Print", "MasterTransaction", new { id = Model.Id })', '_blank');
            if (!printWindow) {
                alert('Tolong izinkan pop-up untuk mencetak nota.');
            }
        }
    </script>
}
