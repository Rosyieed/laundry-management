@model LaundryManagement.Models.ViewModels.TransactionEditViewModel

@{
    ViewData["Title"] = "Edit Transaksi";
    bool isAdmin = User.IsInRole("Admin") || User.IsInRole("Owner");
    bool canEditItems = Model.CurrentStatus == "Pending" || (Model.CurrentStatus == "Process" && isAdmin);
    bool canEditStatus = Model.CurrentStatus != "Taken";
}

@section PageHeader {
    <div class="row">
        <div class="col-sm-6">
            <h3 class="mb-0">Edit Transaksi: @Model.InvoiceNo</h3>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Transaksi</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </div>
    </div>
}

<form asp-action="Edit" method="post" id="editForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="InvoiceNo" />
    <input type="hidden" asp-for="CurrentStatus" />

    <div class="row">
        <div class="col-md-8">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">Keranjang Layanan</h3>
                    @if (!canEditItems)
                    {
                        <span class="badge bg-danger float-end"><i class="fa-solid fa-lock"></i> Terkunci</span>
                    }
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    @if (canEditItems)
                    {
                        <!-- Input Pencarian / Pemilihan Jasa -->
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <select id="selectPricelist" class="form-control form-select select2">
                                    <option value="">-- Pilih Layanan / Pricelist --</option>
                                    @foreach (var item in ViewBag.Pricelists)
                                    {
                                        <option value="@item.Id" data-price="@item.Price" data-satuan="@item.Satuan">@item.DisplayText</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button type="button" id="btnAddItem" class="btn btn-success w-100">
                                    <i class="fa-solid fa-plus"></i> Tambah Item
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Tabel Keranjang -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped" id="cartTable">
                            <thead class="bg-light">
                                <tr>
                                    <th>Layanan</th>
                                    <th style="width: 15%">Harga (Rp)</th>
                                    <th style="width: 15%">Qty</th>
                                    <th style="width: 15%">Diskon (Rp)</th>
                                    <th style="width: 20%">Subtotal (Rp)</th>
                                    @if (canEditItems)
                                    {
                                        <th style="width: 5%">Aksi</th>
                                    }
                                </tr>
                            </thead>
                            <tbody id="cartBody">
                                @if (Model.Details != null && Model.Details.Count > 0)
                                {
                                    int idx = 0;
                                    foreach (var detail in Model.Details)
                                    {
                                        <tr class="item-row">
                                            <td class="align-middle">
                                                @detail.JasaName
                                                @if (canEditItems)
                                                {
                                                    <input type="hidden" name="Details[@idx].PricelistJasaId" class="item-id-input" value="@detail.PricelistJasaId" />
                                                    <input type="hidden" name="Details[@idx].PriceAtTime" class="price-input" value="@detail.PriceAtTime" />
                                                }
                                                else
                                                {
                                                    <input type="hidden" class="price-input" value="@detail.PriceAtTime" />
                                                }
                                            </td>
                                            <td class="align-middle">@detail.PriceAtTime.ToString("N0")</td>
                                            <td class="align-middle">
                                                @if (canEditItems)
                                                {
                                                    <input type="number" step="any" min="0.1" class="form-control form-control-sm qty-input" name="Details[@idx].Qty" value="@detail.Qty.ToString("G29")" required>
                                                }
                                                else
                                                {
                                                    <input type="hidden" class="qty-input" value="@detail.Qty.ToString("G29")" />
                                                    @detail.Qty.ToString("G29")
                                                }
                                            </td>
                                            <td class="align-middle">
                                                @if (canEditItems)
                                                {
                                                    <input type="number" step="any" min="0" class="form-control form-control-sm disc-input" name="Details[@idx].Discount" value="@detail.Discount.ToString("G29")">
                                                }
                                                else
                                                {
                                                    <input type="hidden" class="disc-input" value="@detail.Discount.ToString("G29")" />
                                                    @detail.Discount.ToString("N0")
                                                }
                                            </td>
                                            <td class="align-middle line-subtotal fw-bold text-end">
                                                @{
                                                    decimal st = (detail.Qty * detail.PriceAtTime) - detail.Discount;
                                                }
                                                @st.ToString("N0")
                                            </td>
                                            @if (canEditItems)
                                            {
                                                <td class="text-center align-middle">
                                                    <button type="button" class="btn btn-danger btn-sm btn-remove"><i class="fa-solid fa-xmark"></i></button>
                                                </td>
                                            }
                                        </tr>
                                        idx++;
                                    }
                                }
                                else
                                {
                                    <tr id="emptyRow">
                                        <td colspan="@(canEditItems ? 6 : 5)" class="text-center text-muted">Belum ada layanan yang dipilih.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN: Detail Pelanggan & Pembayaran -->
        <div class="col-md-4">
            <!-- Card Pelanggan -->
            <div class="card card-info card-outline mb-3">
                <div class="card-header">
                    <h3 class="card-title"><i class="fa-solid fa-user me-1"></i> Pelanggan</h3>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Nama:</strong> @Model.CustomerName</p>
                    <p class="mb-0"><strong>No. HP:</strong> @Model.CustomerPhone</p>
                    <input type="hidden" asp-for="CustomerId" />
                </div>
            </div>

            <!-- Card Tagihan & Simpan -->
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title"><i class="fa-solid fa-money-bill-wave me-1"></i> Form Pengubahan</h3>
                </div>
                <div class="card-body">
                    <!-- Kalkulasi Harga Tampil -->
                    <div class="row mb-2">
                        <div class="col-6"><strong>Subtotal:</strong></div>
                        <div class="col-6 text-end"><span id="lblSubtotal">Rp 0</span></div>
                    </div>
                    <div class="row mb-2 text-danger">
                        <div class="col-6"><strong>Diskon:</strong></div>
                        <div class="col-6 text-end">- <span id="lblDiscount">Rp 0</span></div>
                    </div>
                    <hr />
                    <div class="row mb-3">
                        <div class="col-5"><h4><strong>TOTAL:</strong></h4></div>
                        <div class="col-7 text-end text-success"><h4 id="lblGrandTotal"><strong>Rp 0</strong></h4></div>
                    </div>

                    <!-- Status Utama -->
                    <div class="form-group mb-3 border p-2 bg-light">
                        <label asp-for="Status" class="form-label text-primary">Tahap Pengerjaan (Status)</label>
                        @if (canEditStatus)
                        {
                            <select asp-for="Status" class="form-control form-select">
                                @if (Model.CurrentStatus == "Finished")
                                {
                                    <option value="Finished">Selesai Dicuci (Finished)</option>
                                    <option value="Taken">Sudah Diambil (Taken)</option>
                                }
                                else
                                {
                                    <option value="Pending">Antrean Baru (Pending)</option>
                                    <option value="Process">Sedang Diproses (Process)</option>
                                    <option value="Finished">Selesai Dicuci (Finished)</option>
                                    <option value="Taken">Sudah Diambil (Taken)</option>
                                }
                            </select>
                            <small class="text-muted d-block mt-1">Perhatian: Ubah ke 'Taken' akan mengunci transaksi.</small>
                        }
                        else
                        {
                            <input type="hidden" asp-for="Status" />
                            <div class="form-control bg-e9ecef" readonly>@Model.Status (Terkunci)</div>
                        }
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="PaymentStatus" class="form-label">Status Pembayaran</label>
                        @if (canEditStatus)
                        {
                            <select asp-for="PaymentStatus" class="form-control form-select">
                                <option value="Unpaid">Belum Lunas (Unpaid)</option>
                                <option value="Paid">Lunas (Paid)</option>
                            </select>
                        }
                        else
                        {
                            <input type="hidden" asp-for="PaymentStatus" />
                            <div class="form-control bg-e9ecef" readonly>@Model.PaymentStatus</div>
                        }
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="PaymentMethod" class="form-label">Metode Pembayaran</label>
                        @if (canEditStatus)
                        {
                            <select asp-for="PaymentMethod" class="form-control form-select">
                                <option value="Cash">Cash (Tunai)</option>
                                <option value="QRIS">QRIS</option>
                                <option value="Transfer">Transfer Bank</option>
                            </select>
                        }
                        else
                        {
                            <input type="hidden" asp-for="PaymentMethod" />
                            <div class="form-control bg-e9ecef" readonly>@Model.PaymentMethod</div>
                        }
                    </div>

                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group mb-3">
                                <label asp-for="OrderDate" class="form-label">Tanggal Order</label>
                                @if (canEditStatus)
                                {
                                    <input asp-for="OrderDate" class="form-control" type="date" required />
                                }
                                else
                                {
                                    <input type="hidden" asp-for="OrderDate" />
                                    <div class="form-control bg-e9ecef" readonly>@Model.OrderDate.ToString("yyyy-MM-dd")</div>
                                }
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group mb-3">
                                <label asp-for="EstimatedFinishDate" class="form-label">Estimasi Selesai</label>
                                @if (canEditStatus)
                                {
                                    <input asp-for="EstimatedFinishDate" class="form-control" type="date" />
                                }
                                else
                                {
                                    <input type="hidden" asp-for="EstimatedFinishDate" />
                                    <div class="form-control bg-e9ecef" readonly>@(Model.EstimatedFinishDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Notes" class="form-label">Catatan Trx</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="opsional..."></textarea>
                        <small class="text-muted">Catatan selalu bisa diedit.</small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="fa-solid fa-save me-1"></i> Simpan Perubahan
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Batal</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            if ($.fn.select2) {
                $('.select2').select2();
            }

            var itemIndex = @(Model.Details?.Count ?? 0);
            var canEdit = @(canEditItems ? "true" : "false");

            function formatRupiah(number) {
                return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(number);
            }

            function formatNumberPlain(number) {
                let s = number.toString().replace('.', ',');
                return s;
            }

            function calculateTotals() {
                let subTotal = 0;
                let discount = 0;

                $('#cartBody tr.item-row').each(function () {
                    let price = parseFloat($(this).find('.price-input').val()) || 0;
                    let qty = parseFloat($(this).find('.qty-input').val()) || 0;
                    let disc = parseFloat($(this).find('.disc-input').val()) || 0;

                    let lineTotal = (price * qty) - disc;
                    if (lineTotal < 0) lineTotal = 0;

                    $(this).find('.line-subtotal').text(formatRupiah(lineTotal));

                    subTotal += (price * qty);
                    discount += disc;
                });

                let grandTotal = subTotal - discount;

                $('#lblSubtotal').text(formatRupiah(subTotal));
                $('#lblDiscount').text(formatRupiah(discount));
                $('#lblGrandTotal').text(formatRupiah(grandTotal < 0 ? 0 : grandTotal));
            }

            // Hitung pertama kali load
            calculateTotals();

            if (canEdit) {
                $('#btnAddItem').click(function () {
                    let select = $('#selectPricelist');
                    let option = select.find('option:selected');

                    let id = option.val();
                    let name = option.text();
                    let price = option.data('price');

                    if (!id) {
                        alert('Silakan pilih layanan terlebih dahulu!');
                        return;
                    }

                    let exists = false;
                    $('.item-id-input').each(function () {
                        if ($(this).val() == id) {
                            exists = true;
                        }
                    });

                    if (exists) {
                        alert('Layanan tersebut sudah ada di keranjang. Silakan sesuaikan Qty.');
                        return;
                    }

                    $('#emptyRow').hide();

                    let rowHtml = `
                        <tr class="item-row">
                            <td class="align-middle">
                                ${name}
                                <input type="hidden" name="Details[${itemIndex}].PricelistJasaId" class="item-id-input" value="${id}" />
                                <input type="hidden" name="Details[${itemIndex}].PriceAtTime" class="price-input" value="${price}" />
                            </td>
                            <td class="align-middle">${formatRupiah(price)}</td>
                            <td class="align-middle">
                                <input type="number" step="any" min="0.1" class="form-control form-control-sm qty-input" name="Details[${itemIndex}].Qty" value="1" required>
                            </td>
                            <td class="align-middle">
                                <input type="number" step="any" min="0" class="form-control form-control-sm disc-input" name="Details[${itemIndex}].Discount" value="0">
                            </td>
                            <td class="align-middle line-subtotal fw-bold text-end">
                                ${formatRupiah(price)}
                            </td>
                            <td class="text-center align-middle">
                                <button type="button" class="btn btn-danger btn-sm btn-remove"><i class="fa-solid fa-xmark"></i></button>
                            </td>
                        </tr>
                    `;

                    $('#cartBody').append(rowHtml);
                    itemIndex++;
                    calculateTotals();

                    select.val('').trigger('change');
                });

                $(document).on('input', '.qty-input, .disc-input', function () {
                    calculateTotals();
                });

                $(document).on('click', '.btn-remove', function () {
                    $(this).closest('tr').remove();
                    calculateTotals();

                    // Re-index
                    $('#cartBody tr.item-row').each(function (idx) {
                        $(this).find('.item-id-input').attr('name', `Details[${idx}].PricelistJasaId`);
                        $(this).find('.price-input').attr('name', `Details[${idx}].PriceAtTime`);
                        $(this).find('.qty-input').attr('name', `Details[${idx}].Qty`);
                        $(this).find('.disc-input').attr('name', `Details[${idx}].Discount`);
                    });

                    itemIndex = $('#cartBody tr.item-row').length;
                    if (itemIndex === 0) {
                        $('#emptyRow').show();
                    }
                });
            }
        });
    </script>
}
