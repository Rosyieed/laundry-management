@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

@section Styles {
    <style>
      .logo-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            width: 100px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
    </style>
}

<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
        <!--begin::Sidebar Brand-->
        <div class="sidebar-brand">
          <!--begin::Brand Link-->
          <a asp-controller="Home" asp-action="Index" class="brand-link">
            <!--begin::Brand Image-->
            <div class="logo-container">
                <i class="fa-solid fa-shirt" style="color: white;"></i>
            </div>
            <!--end::Brand Image-->
            <!--begin::Brand Text-->
            <span class="brand-text fw-light">Laundry Management</span>
            <!--end::Brand Text-->
          </a>
          <!--end::Brand Link-->
        </div>
        <!--end::Sidebar Brand-->
        <!--begin::Sidebar Wrapper-->
        <div class="sidebar-wrapper">
          <nav class="mt-2">
            <!--begin::Sidebar Menu-->
            <ul
              class="nav sidebar-menu flex-column"
              data-lte-toggle="treeview"
              role="navigation"
              aria-label="Main navigation"
              data-accordion="false"
              id="navigation"
            >
              @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
              {
                  <li class="nav-header">MASTER</li>
              }
              @if (User.IsInRole("Owner"))
              {
                  <li class="nav-item">
                     <a asp-controller="MasterUser"
                        asp-action="Index"
                        class="nav-link @(controller == "MasterUser" ? "active" : "")">
                        <i class="nav-icon fa-solid fa-users"></i>
                        <p>User Management</p>
                    </a>
                  </li>
              }
              @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
              {
                  <li class="nav-item">
                     <a asp-controller="MasterJasa"
                        asp-action="Index"
                        class="nav-link @(controller == "MasterJasa" ? "active" : "")">
                        <i class="nav-icon fa-solid fa-boxes-stacked"></i>
                        <p>Jasa Management</p>
                    </a>
                  </li>
                  <li class="nav-item">
                     <a asp-controller="MasterPricelist"
                        asp-action="Index"
                        class="nav-link @(controller == "MasterPricelist" ? "active" : "")">
                        <i class="nav-icon fa-solid fa-hand-holding-dollar"></i>
                        <p>Pricelist Management</p>
                    </a>
                  </li>
              }
              @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
              {
                  <li class="nav-item">
                     <a asp-controller="MasterCustomer"
                        asp-action="Index"
                        class="nav-link @(controller == "MasterCustomer" ? "active" : "")">
                        <i class="nav-icon fa-solid fa-address-book"></i>
                        <p>Customer Management</p>
                    </a>
                  </li>
              }
            </ul>

            <!-- TRANSAKSI -->
            @if (User.IsInRole("Owner") || User.IsInRole("Admin") || User.IsInRole("Kasir"))
            {
                <ul
                  class="nav sidebar-menu flex-column"
                  data-lte-toggle="treeview"
                  role="navigation"
                  aria-label="Main navigation"
                  data-accordion="false"
                  id="navigation"
                >
                    <li class="nav-header">TRANSAKSI</li>
                    <li class="nav-item">
                        <a asp-controller="MasterTransaction" asp-action="Create" class="nav-link @(controller == "MasterTransaction" && action == "Create" ? "active" : "")">
                            <i class="nav-icon fa-solid fa-cash-register"></i>
                            <p>POS (Kasir)</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="MasterTransaction" asp-action="Index" class="nav-link @(controller == "MasterTransaction" && (action == "Index" || action == "Edit" || action == "Print" || action == "Details") ? "active" : "")">
                            <i class="nav-icon fa-solid fa-file-invoice-dollar"></i>
                            <p>Histori Transaksi</p>
                        </a>
                    </li>
                </ul>
            }
            <!--end::Sidebar Menu-->
          </nav>
        </div>
        <!--end::Sidebar Wrapper-->
      </aside>