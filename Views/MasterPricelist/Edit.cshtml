@model LaundryManagement.Models.ViewModels.PricelistJasaViewModel

@{
    ViewData["Title"] = "Ubah Pricelist Jasa";
}

@section PageHeader {
    <div class="row">
        <div class="col-sm-6">
            <h3 class="mb-0">Ubah Pricelist Jasa</h3>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a href="#">Master</a></li>
                <li class="breadcrumb-item"><a asp-controller="MasterPricelist" asp-action="Index">Pricelist Management</a></li>
                <li class="breadcrumb-item active" aria-current="page">Ubah</li>
            </ol>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-12">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title">Form Ubah Pricelist</h3>
            </div>
            
            <form asp-controller="MasterPricelist" asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group mb-3">
                                <label asp-for="JasaId" class="form-label">Nama Jasa</label>
                                <select asp-for="JasaId" class="form-control form-select" asp-items="ViewBag.Jasas" required>
                                    <option value="">-- Pilih Jasa --</option>
                                </select>
                                <span asp-validation-for="JasaId" class="text-danger text-sm"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="TipeLayanan" class="form-label">Tipe Layanan</label>
                                <select asp-for="TipeLayanan" class="form-control form-select" asp-items="ViewBag.TipeLayananOptions" required>
                                    <option value="">-- Pilih Tipe Layanan --</option>
                                </select>
                                <span asp-validation-for="TipeLayanan" class="text-danger text-sm"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Harga" class="form-label">Harga (Rp)</label>
                                <input asp-for="Harga" type="number" step="any" class="form-control" placeholder="Masukkan harga IDR" required />
                                <span asp-validation-for="Harga" class="text-danger text-sm"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->

                <div class="card-footer d-flex justify-content-end">
                    <a asp-controller="MasterPricelist" asp-action="Index" class="btn btn-secondary btn-sm me-2"> 
                        <i class="fa-solid fa-arrow-left"></i> Batal
                    </a>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-save"></i> Simpan Perubahan
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
