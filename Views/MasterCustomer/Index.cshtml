@model IEnumerable<LaundryManagement.Models.Entities.Customer>

@{
    ViewData["Title"] = "Customer Management";
}

@section PageHeader {
    <div class="row">
        <div class="col-sm-6">
            <h3 class="mb-0">Customer Management</h3>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a href="#">Master</a></li>
                <li class="breadcrumb-item active" aria-current="page">Customer Management</li>
            </ol>
        </div>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Customer Management</h3>
        <a asp-controller="MasterCustomer" asp-action="Create" class="btn btn-primary btn-sm float-end"><i class="fa-solid fa-plus"></i> Tambah</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover" id="myTable">
            <thead>
                <tr>
                    <th class="text-center" style="width: 5%">No</th>
                    <th class="text-left">Nama</th>
                    <th class="text-left">No. Telepon</th>
                    <th class="text-left">Alamat</th>
                    <th class="text-center">Status</th>
                    <th class="text-center" style="width: 15%">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center align-middle">@i</td>
                        <td class="text-left align-middle">@item.Name</td>
                        <td class="text-left align-middle">@item.PhoneNumber</td>
                        <td class="text-left align-middle">@(string.IsNullOrEmpty(item.Address) ? "-" : item.Address)</td>
                        <td class="text-center align-middle">
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Tidak Aktif</span>
                            }
                        </td>
                        <td class="text-center align-middle">
                            <a asp-controller="MasterCustomer" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen-to-square"></i> Ubah</a>
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#myTable').DataTable({
                language: {
                    url: "//cdn.datatables.net/plug-ins/1.13.8/i18n/id.json"
                }
            });
        });
    </script>
}
