@model LaundryManagement.Models.ViewModels.CustomerViewModel

@{
    ViewData["Title"] = "Ubah Customer";
}

@section PageHeader {
    <div class="row">
        <div class="col-sm-6">
            <h3 class="mb-0">Ubah Customer</h3>
        </div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-end">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a href="#">Master</a></li>
                <li class="breadcrumb-item"><a asp-controller="MasterCustomer" asp-action="Index">Customer Management</a></li>
                <li class="breadcrumb-item active" aria-current="page">Ubah</li>
            </ol>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-12">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card card-secondary">
            <div class="card-header">
                <h3 class="card-title">Form Ubah Customer</h3>
            </div>
            
            <form asp-controller="MasterCustomer" asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Name" class="form-label">Nama Lengkap</label>
                                <input asp-for="Name" class="form-control" placeholder="Masukkan nama pelanggan" required />
                                <span asp-validation-for="Name" class="text-danger text-sm"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="PhoneNumber" class="form-label">Nomor Telepon</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Nomor Handphone / WhatsApp" type="tel" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger text-sm"></span>
                            </div>

                            <div class="form-group mb-3">
                                <div class="form-check form-switch mt-4">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch">
                                    <label class="form-check-label" for="IsActiveSwitch">Status Aktif</label>
                                </div>
                                <span asp-validation-for="IsActive" class="text-danger text-sm"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Address" class="form-label">Alamat Lengkap</label>
                                <textarea asp-for="Address" class="form-control" rows="4" placeholder="Alamat pelanggan..."></textarea>
                                <span asp-validation-for="Address" class="text-danger text-sm"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->

                <div class="card-footer d-flex justify-content-end">
                    <a asp-controller="MasterCustomer" asp-action="Index" class="btn btn-secondary btn-sm me-2"> 
                        <i class="fa-solid fa-arrow-left"></i> Batal
                    </a>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-save"></i> Simpan Perubahan
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
