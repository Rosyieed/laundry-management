@model LaundryManagement.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Laundry System | @ViewData["Title"]</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
        .login-container {
            min-height: 100vh;
        }
        .bg-image {
            background-image: linear-gradient(135deg, #4b545c 0%, #343a40 100%);
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .bg-image::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.2);
        }
        .login-content {
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            height: 100%;
            max-width: 500px;
            margin: 0 auto;
        }
        .login-header {
            margin-bottom: 2rem;
            text-align: center;
        }
        .login-header h1 {
            font-weight: 700;
            color: #2b3445;
            letter-spacing: -0.5px;
        }
        .login-header p {
            color: #7d879c;
        }
        .form-control {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            border: 1px solid #e3e9ef;
            background-color: #f3f5f9;
            transition: all 0.3s;
        }
        .form-control:focus {
            background-color: #fff;
            border-color: #343a40;
            box-shadow: 0 0 0 0.25rem rgba(52, 58, 64, 0.25);
        }
        .input-group-text {
            background-color: #f3f5f9;
            border: 1px solid #e3e9ef;
            border-left: none;
            border-radius: 0 0.5rem 0.5rem 0;
            cursor: pointer;
        }
        .input-group-text.left-icon {
            border-right: none;
            border-left: 1px solid #e3e9ef;
            border-radius: 0.5rem 0 0 0.5rem;
        }
        .form-control.password-input {
            border-right: none;
            border-radius: 0.5rem 0 0 0.5rem;
        }
        .btn-primary {
            background: #343a40;
            border: none;
            padding: 0.75rem;
            border-radius: 0.5rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }
        .btn-primary:hover {
            background: #23272b;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(52, 58, 64, 0.3);
        }
        .welcome-text {
            position: relative;
            z-index: 1;
            color: white;
            text-align: center;
            padding: 3rem;
        }
        .welcome-text h2 {
            font-weight: 700;
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .welcome-text p {
            font-size: 1.1rem;
            opacity: 0.9;
        }
        /* Glass styling for logo container */
        .logo-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            width: 100px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .logo-container i {
            font-size: 40px;
            color: white;
        }
    </style>
</head>
<body>

<div class="container-fluid login-container">
    <div class="row h-100" style="min-height: 100vh;">
        <!-- Left Side: Image/Branding -->
        <div class="col-lg-6 col-md-5 d-none d-md-flex flex-column justify-content-center bg-image">
            <div class="welcome-text">
                <div class="logo-container">
                    <i class="fa-solid fa-shirt"></i>
                </div>
                <h2>Laundry Management System</h2>
                <p>Kelola operasional laundry Anda dengan lebih mudah, cepat, dan efisien dalam satu platform terpadu.</p>
            </div>
        </div>

        <!-- Right Side: Login Form -->
        <div class="col-lg-6 col-md-7 d-flex align-items-center bg-white shadow-lg justify-content-center">
            <div class="login-content w-100 px-4 px-md-5" style="max-width: 450px;">
                
                <div class="login-header">
                    <div class="d-md-none mb-4">
                        <i class="fa-solid fa-shirt fa-3x" style="color: #343a40;"></i>
                    </div>
                    <h1>Selamat Datang</h1>
                    <p>Silakan masuk ke akun Anda</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" style="border-radius: 0.5rem;" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-circle-exclamation me-2 fs-5"></i>
                            <div>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span class="d-block" style="font-size: 0.9rem;">@error.ErrorMessage</span>
                                }
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    
                    <div class="mb-4">
                        <label asp-for="Username" class="form-label fw-semibold text-dark">Username</label>
                        <div class="input-group">
                            <span class="input-group-text left-icon bg-light text-muted px-3" style="border-right: none;" id="basic-addon1">
                                <i class="fa-solid fa-user"></i>
                            </span>
                            <input asp-for="Username" class="form-control border-start-0 ps-0" aria-describedby="basic-addon1" placeholder="Masukkan username" required autofocus>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="form-label fw-semibold text-dark mb-0">Password</label>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text left-icon bg-light text-muted px-3" style="border-right: none;" id="basic-addon2">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 border-end-0 ps-0 password-input" id="passwordInput" placeholder="Masukkan password" aria-describedby="basic-addon2" required>
                            <span class="input-group-text px-3" id="togglePassword">
                                <i class="fa-solid fa-eye text-muted" id="eyeIcon"></i>
                            </span>
                        </div>
                    </div>
                    
                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" asp-for="RememberMe" id="remember">
                        <label class="form-check-label text-muted" for="remember">
                            Ingat sesi saya
                        </label>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 py-3 mt-2 fs-6 text-white shadow-sm">
                        Masuk <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                    </button>
                    
                </form>
                
                <div class="mt-5 text-center text-muted text-sm" style="font-size: 0.85rem;">
                    &copy; @DateTime.Now.Year - Laundry System. <br/>All rights reserved.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function() {
        // Toggle Password Visibility
        $("#togglePassword").click(function() {
            var passInput = $("#passwordInput");
            var eyeIcon = $("#eyeIcon");
            if (passInput.attr("type") === "password") {
                passInput.attr("type", "text");
                eyeIcon.removeClass("fa-eye").addClass("fa-eye-slash");
            } else {
                passInput.attr("type", "password");
                eyeIcon.removeClass("fa-eye-slash").addClass("fa-eye");
            }
        });

        // Focus UI logic for input-groups
        $('.form-control').on('focus', function() {
            var $group = $(this).closest('.input-group');
            $group.find('.input-group-text').css({
                'border-color': '#343a40',
                'background-color': '#fff'
            });
            $(this).css({
                'border-color': '#343a40',
                'background-color': '#fff'
            });
            $group.css('box-shadow', '0 0 0 0.25rem rgba(52, 58, 64, 0.25)');
            $group.css('border-radius', '0.5rem');
        }).on('blur', function() {
            var $group = $(this).closest('.input-group');
            $group.find('.input-group-text').css({
                'border-color': '#e3e9ef',
                'background-color': '#f3f5f9'
            });
            $(this).css({
                'border-color': '#e3e9ef',
                'background-color': '#f3f5f9'
            });
            $group.css('box-shadow', 'none');
        });
    });
</script>
</body>
</html>
