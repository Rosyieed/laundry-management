@{
    Layout = null;
    ViewData["Title"] = "Akses Ditolak";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Laundry System | @ViewData["Title"]</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    
    <style>
        body {
            background-color: #f4f6f9;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }
        .error-page {
            max-width: 600px;
            text-align: center;
            padding: 2rem;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .error-page h1 {
            font-size: 80px;
            color: #dc3545;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="error-page">
        <h1>403</h1>
        <h3><i class="fas fa-exclamation-triangle text-danger"></i> Akses Ditolak</h3>
        <p class="text-muted mt-3">
            Maaf, Anda tidak memiliki izin untuk mengakses halaman ini. Halaman ini butuh hak akses <strong>Owner</strong>.
        </p>
        <a href="/" class="btn btn-primary mt-3"><i class="fas fa-home me-2"></i> Kembali ke Dashboard</a>
    </div>
</body>
</html>
